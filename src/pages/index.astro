---
import "../styles/styles.css";
import { HomePage } from "../components/HomePage.tsx";
import { BottomNav } from "../components/BottomNav.tsx";

const site = "https://earnlog.xyz";
const title = "DriverStack — Know what you really make driving";
const description = "Real hourly pay for California rideshare and delivery drivers after gas, miles, waiting time, and platform switching.";
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="earnlog.xyz" />
    <meta name="theme-color" content="#1a1f24" />
    <link rel="canonical" href={site} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={site} />
    <meta property="og:site_name" content="earnlog.xyz" />

    <!-- Twitter card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- JSON-LD structured data: Organization + WebSite (static; domain
         is known at scaffold time. Update description by hand if needed.) -->
    <script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://earnlog.xyz/#organization",
      "name": "earnlog.xyz",
      "url": "https://earnlog.xyz/"
    },
    {
      "@type": "WebSite",
      "@id": "https://earnlog.xyz/#website",
      "url": "https://earnlog.xyz/",
      "name": "earnlog.xyz",
      "publisher": { "@id": "https://earnlog.xyz/#organization" }
    }
  ]
}
    </script>
  </head>
  <body>
    <div class="mx-auto min-h-screen max-w-md pb-24">
      <HomePage client:load />
    </div>
    <BottomNav client:load />
  </body>
</html>
