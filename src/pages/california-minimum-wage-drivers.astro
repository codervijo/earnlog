---
import Layout from "../layouts/Layout.astro";
import GuideLinks from "../components/GuideLinks.astro";

const title = "Does your gig shift beat California minimum wage? ($16.90 in 2026) — DriverStack";
const description =
  "California's minimum wage is $16.90/hour in 2026, and many cities are higher. Here's how that benchmark applies to gig drivers — who are independent contractors — and how to check your real hourly against it.";
const path = "/california-minimum-wage-drivers";

const published = "2026-06-27";
const modified = "2026-06-27";

// City floors above the $16.90 statewide minimum (2026). The applicable wage is
// set by where the work is performed; full local list at the UC Berkeley Labor Center.
const cities = [
  { city: "California (statewide floor)", wage: "$16.90" },
  { city: "Los Angeles", wage: "$17.87" },
  { city: "San Francisco", wage: "~$18.67" },
];

const faq = [
  {
    q: "What is the California minimum wage in 2026?",
    a: "The California statewide minimum wage is $16.90 per hour, effective January 1, 2026 (up from $16.50 in 2025), for all employers. Many cities set a higher local minimum — for example Los Angeles ($17.87) and San Francisco (about $18.67). The applicable rate is set by where the work is performed, not where you live.",
  },
  {
    q: "Is gig driving below minimum wage in California?",
    a: "It often is, once you count the real cost of driving. Apps report gross pay, but after subtracting gas and vehicle wear — especially at the IRS full-cost rate of 72.5¢/mile — many shifts net out below the $16.90/hour floor. Whether yours does depends on your pay, miles, and hours; run your shift through the calculator to find out.",
  },
  {
    q: "Do Uber, DoorDash and Instacart have to pay California minimum wage?",
    a: "Not in the same way a W-2 employer does. App-based rideshare and delivery drivers are classified as independent contractors under California's Proposition 22, so the standard $16.90/hour minimum wage is a benchmark for comparison — not a guaranteed hourly wage a contractor is owed. That's exactly why measuring your own real hourly matters: nobody else is guaranteeing it.",
  },
  {
    q: "Which city's minimum wage applies to me?",
    a: "Generally the minimum wage of the city where you perform the work. If you drive across multiple cities, different local rates can apply in different places. Use the statewide $16.90 floor as a conservative benchmark, and check your city's specific rate if it's higher.",
  },
];

const ld = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "@id": "https://earnlog.xyz/california-minimum-wage-drivers/#article",
      headline: "Does your gig shift beat California minimum wage?",
      description,
      datePublished: published,
      dateModified: modified,
      author: { "@id": "https://earnlog.xyz/#organization" },
      publisher: { "@id": "https://earnlog.xyz/#organization" },
      mainEntityOfPage: "https://earnlog.xyz/california-minimum-wage-drivers/",
    },
    {
      "@type": "FAQPage",
      "@id": "https://earnlog.xyz/california-minimum-wage-drivers/#faq",
      mainEntity: faq.map((f) => ({
        "@type": "Question",
        name: f.q,
        acceptedAnswer: { "@type": "Answer", text: f.a },
      })),
    },
  ],
};
---
<Layout title={title} description={description} path={path}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(ld)} />

  <main class="px-5 pt-8">
    <div class="text-xs font-bold uppercase tracking-[0.2em] text-primary">California</div>
    <h1 class="mt-3 text-3xl font-black leading-tight tracking-tight">
      Does your gig shift beat California minimum wage?
    </h1>
    <p class="mt-3 text-base text-muted-foreground">
      In 2026 the California minimum wage is <strong class="text-foreground">$16.90/hour</strong>.
      Your driving apps will never tell you whether your shift cleared it. After gas and
      mileage, a lot of shifts don't. Here's how the benchmark works for drivers — and the
      one distinction that matters.
    </p>
    <p class="mt-2 text-xs text-muted-foreground">
      Last updated June 2026 · Methodology: real hourly = (gross pay − driving cost) ÷ online
      hours, compared against the $16.90 statewide floor.
    </p>

    <section class="mt-8">
      <h2 class="text-lg font-bold">The 2026 number: $16.90 (and higher in some cities)</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        The statewide minimum rose to $16.90/hour on January 1, 2026 (from $16.50). Many
        California cities set a higher local floor, and the rate that applies is set by
        <strong class="text-foreground">where you do the work</strong>, not where you live.
      </p>
      <div class="mt-4 overflow-hidden rounded-2xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-card text-left text-xs uppercase tracking-wider text-muted-foreground">
              <th class="px-4 py-3 font-medium">Where you work</th>
              <th class="px-4 py-3 text-right font-medium">2026 minimum</th>
            </tr>
          </thead>
          <tbody class="num">
            {cities.map((c) => (
              <tr class="border-t border-border">
                <td class="px-4 py-3">{c.city}</td>
                <td class="px-4 py-3 text-right font-bold">{c.wage}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-muted-foreground">
        Source: California Dept. of Industrial Relations
        (<a class="text-primary underline" href="https://www.dir.ca.gov/dlse/minimum_wage.htm" rel="nofollow noopener" target="_blank">dir.ca.gov</a>).
        A full, maintained list of local rates is published by the UC Berkeley Labor Center.
      </p>
    </section>

    <section class="mt-8 rounded-2xl border border-primary/30 bg-primary/10 p-5">
      <h2 class="text-base font-bold text-primary">The distinction that matters: you're a contractor</h2>
      <p class="mt-2 text-sm text-foreground/90">
        App-based drivers are classified as <strong>independent contractors</strong> under
        California's Proposition 22. That means the $16.90 minimum wage is a
        <strong>benchmark you can measure yourself against — not a wage the platform legally
        guarantees you per hour</strong> the way a W-2 job would. Standard minimum-wage
        protections, overtime, and "engaged vs total time" rules work differently for
        contractors. So the honest question isn't "are they paying me minimum wage?" — it's
        <em>"is what I'm actually clearing more or less than minimum wage?"</em> That's the
        number this site exists to show you.
      </p>
    </section>

    <section class="mt-8">
      <h2 class="text-lg font-bold">How to check your own shift</h2>
      <p class="mt-2 text-sm text-muted-foreground">
        Take your gross pay, subtract your real driving cost (we recommend the
        <a class="text-primary underline" href="/cost-per-mile/">IRS full-cost 72.5¢/mile</a>
        model), and divide by the hours you were online. If the result is under $16.90, your
        shift came in below California minimum wage — even if the app showed a bigger number.
        See a <a class="text-primary underline" href="/is-doordash-worth-it-california/">fully
        worked example</a>, or run your own shift.
      </p>
    </section>

    <section class="mt-10">
      <h2 class="text-lg font-bold">FAQ</h2>
      <div class="mt-3 space-y-2.5">
        {faq.map((f) => (
          <details class="rounded-2xl border border-border bg-card p-4">
            <summary class="cursor-pointer text-sm font-semibold">{f.q}</summary>
            <p class="mt-2 text-sm text-muted-foreground">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <GuideLinks current={path + "/"} />
  </main>
</Layout>
