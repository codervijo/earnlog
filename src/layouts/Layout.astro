---
import "../styles/styles.css";
import { BottomNav } from "../components/BottomNav.tsx";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  noindex?: boolean;
}

const site = "https://earnlog.xyz";
const {
  title = "DriverStack — Know what you really make driving",
  description = "DriverStack shows California gig drivers their real hourly pay after gas, miles, waiting time, and platform switching.",
  path = "",
  noindex = false,
} = Astro.props;
// Astro's directory format serves pages at /<path>/ and @astrojs/sitemap lists
// them with the trailing slash; ensure the canonical matches the served URL
// (a canonical pointing at /<path> 308-redirects to /<path>/ — an indexing
// blocker that leaves sub-pages "unknown to Google").
const canonical = `${site}${path}`.replace(/\/?$/, "/");
---
<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <meta name="theme-color" content="#1a1f24" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="earnlog.xyz" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Sitewide Organization + WebSite structured data (every Layout page).
         sameAs is empty until real public profiles exist — fill in below. -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": "https://earnlog.xyz/#organization",
          "name": "DriverStack",
          "alternateName": "earnlog.xyz",
          "url": "https://earnlog.xyz/",
          "description": "Real hourly pay calculator for California gig drivers — Uber, Lyft, DoorDash, Instacart, Uber Eats and more.",
          // TODO: add real public profile URLs (e.g. X/Twitter, LinkedIn, GitHub) once they exist.
          "sameAs": []
        },
        {
          "@type": "WebSite",
          "@id": "https://earnlog.xyz/#website",
          "url": "https://earnlog.xyz/",
          "name": "DriverStack",
          "publisher": { "@id": "https://earnlog.xyz/#organization" }
        }
      ]
    })} />

    <!-- Page-specific structured data (Article / FAQPage / WebApplication) -->
    <slot name="head" />
  </head>
  <body>
    <div class="mx-auto min-h-screen max-w-md pb-24">
      <slot />
    </div>
    <BottomNav client:load />
  </body>
</html>
